<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/DOLCE/OWL/DOLCEepistemic"
     xml:base="https://w3id.org/DOLCE/OWL/DOLCEepistemic"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:ace_lexicon="http://attempto.ifi.uzh.ch/ace_lexicon#"
     xmlns:DOLCEnaryRel="https://w3id.org/DOLCE/OWL/DOLCEnaryRel#"
     xmlns:DOLCEepistemic="https://w3id.org/DOLCE/OWL/DOLCEepistemic#">
    <owl:Ontology rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic">
        <owl:imports rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEnaryRel/4.5"/>
        <terms:creator>Alessandro Mosca</terms:creator>
        <terms:creator>Claudio Masolo</terms:creator>
        <terms:creator>Daniele Porello</terms:creator>
        <terms:creator>Emilio M. Sanfilippo</terms:creator>
        <terms:creator>Roberta Ferrario</terms:creator>
        <terms:creator>Stefano Borgo</terms:creator>
        <terms:creator>Walter Terkaj</terms:creator>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/4.0"/>
        <rdfs:comment>Module representing social and epistemic aspects of knowledge representation</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEbasic#presentAt -->

    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEbasic#presentAt">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#tempClassifiedParticular"/>
            </rdf:Description>
            <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEnaryRel#rRelTime"/>
        </owl:propertyChainAxiom>
    </rdf:Description>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnEndurant -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnEndurant">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEbasic#Region"/>
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnTime -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnTime">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#TimeInterval"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnConjunction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnConjunction">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNConjunction"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupported -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupported">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNSupport"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupporting -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupporting">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNSupport"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#cnRelata">
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
        <rdfs:comment>This object property is used to collect all the object properties that have contents in their domain specification.
It is not to be directly used in instantiations.</rdfs:comment>
        <rdfs:label>content relata</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#constantClassification -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#constantClassification">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
        <rdfs:comment>constantClassification is the constant version of Classification which is a ternary relation between a concept x, a particular y and time interval t at which y is present. The intended interpretation is that x classifies y as it exists at t.
In this constant version, the concept x classifies y during the whole existence of y.</rdfs:comment>
        <rdfs:label>constant classification</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsConjunction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsConjunction">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsRelata"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsContent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsContent">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsRelata -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsRelata">
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
        <rdfs:comment>This object property is used to collect all the object properties that have observations in their domain specification.
It is not meant to be directly used in instantiations.</rdfs:comment>
        <rdfs:label>observation relata</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsSource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsSource">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#obsRelata"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEbasic#NonPhysicalObject"/>
                    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEbasic#PhysicalObject"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#tempClassificationConcept -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#tempClassificationConcept">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEnaryRel#hasArgument"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#RRelTempClassification"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept"/>
        <rdfs:label>concept in temporary classification relation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#tempClassifiedParticular -->

    <owl:ObjectProperty rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#tempClassifiedParticular">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEnaryRel#hasArgument"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#RRelTempClassification"/>
        <rdfs:range rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
        <rdfs:label>classified particular in temporary classification relation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEbasic#Region -->

    <rdf:Description rdf:about="https://w3id.org/DOLCE/OWL/DOLCEbasic#Region">
        <owl:disjointWith rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
    </rdf:Description>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNConcept -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNConcept">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnEndurant"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Acronym: BCN Concept</rdfs:comment>
        <rdfs:label>Basic Content Concept</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNProperty -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNProperty">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Region"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnEndurant"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Acronym: BCN Property</rdfs:comment>
        <rdfs:label>Basic Content Property</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNQuality -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BCNQuality">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnEndurant"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Endurant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnProperty"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Region"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#bcnTime"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Acronym: BCN Quality</rdfs:comment>
        <rdfs:label>Basic Content Quality</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#BasicContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
        <owl:disjointWith rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ComplexContent"/>
        <rdfs:comment>Acronym: BCN</rdfs:comment>
        <rdfs:label>Basic Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNConjunction -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNConjunction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ComplexContent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnConjunction"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNSupport"/>
        <rdfs:comment>Acronym: CCN Conjuction</rdfs:comment>
        <rdfs:label>Conjuction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNSupport -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#CCNSupport">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ComplexContent"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupported"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupporting"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupported"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ccnSupporting"/>
                                <owl:someValuesFrom rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>Acronym: CCN Support</rdfs:comment>
        <rdfs:label>Support</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#ComplexContent -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ComplexContent">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content"/>
        <rdfs:comment>Acronym: CCN</rdfs:comment>
        <rdfs:label>Complex Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Concept">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#NonAgentiveSocialObject"/>
        <owl:disjointWith rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Observation"/>
        <ace_lexicon:CN_pl>concepts</ace_lexicon:CN_pl>
        <ace_lexicon:CN_sg>concept</ace_lexicon:CN_sg>
        <rdfs:comment>A concept is a non-agentive social object that classifies some other entity. For example, the concept (role) of Student classifies John as a particular student.</rdfs:comment>
        <rdfs:label>Concept</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#Content">
        <rdfs:subClassOf rdf:resource="https://w3id.org/DOLCE/OWL/DOLCEbasic#Abstract"/>
        <rdfs:label>Content</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/DOLCE/OWL/DOLCEepistemic#ObsAssertion -->

    <owl:Class rdf:about="https://w3id.org/DOLCE/OWL/DOLCEepistemic#ObsAssertion">
